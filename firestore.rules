rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global deny - require authentication for all operations
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In this app, we derive admin from the user document's role field.
      // But for rules, we need a secure check.
      // We'll check if the role is 'admin' on the user document.
      // NOTE: get() is allowed but we should be careful with quotas.
      // Alternatively, we look for a document in an 'admins' collection.
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. VALIDATION BLUEPRINTS (Entity schemas)

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'passwordHash', 'role', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.passwordHash is string && data.passwordHash.size() > 0 &&
             data.role in ['admin', 'miner', 'analyst', 'operator'] &&
             data.createdAt is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'category', 'difficultyScale', 'qubitDimension']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 &&
             data.description is string &&
             data.category is string &&
             data.difficultyScale is number &&
             data.qubitDimension is number;
    }

    function isValidCalibrationLog(data) {
      return data.keys().hasAll(['userId', 'username', 'targetIndex', 'resonanceRadius', 'expectedImprovement', 'timestamp']) &&
             data.keys().size() == 6 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.username is string &&
             data.targetIndex is number &&
             data.resonanceRadius is number &&
             data.expectedImprovement is number &&
             data.timestamp is string;
    }

    // --- COLLECTION MATCHES ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Only allow updating passwordHash or role (if admin)
        incoming().diff(existing()).affectedKeys().hasOnly(['passwordHash']) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role']))
      );
      allow delete: if isAdmin();
    }

    // PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && isValidProduct(incoming())) ||
        (request.method == 'update' && isValidProduct(incoming())) ||
        (request.method == 'delete')
      );
    }

    // CALIBRATION LOGS
    match /calibrationLogs/{logId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidCalibrationLog(incoming());
      allow delete: if isAdmin();
    }
  }
}
