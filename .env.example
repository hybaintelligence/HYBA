# HYBA Fullstack Platform Configuration
# Copy to .env for local development.
# In production, inject these via a secrets manager or deployment platform.

# Runtime mode
NODE_ENV=development
HYBA_ENV=development

# Bridge server
HOST=0.0.0.0
PORT=3000
PULVINI_BACKEND_URL=http://127.0.0.1:3001
BACKEND_PROXY_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# Auth / operator credentials (required in production)
JWT_SECRET=replace-with-strong-random-secret
HYBA_OPERATOR_CREDENTIALS=operator:replace-with-strong-password
HYBA_API_KEYS=

# Production mining safety gates
# Live Stratum is enabled automatically when NODE_ENV=production.
# In non-production, set HYBA_ENABLE_LIVE_STRATUM=true only for controlled staging smoke tests.
HYBA_ENABLE_LIVE_STRATUM=false
HYBA_ALLOW_DEV_FIXTURES=false
HYBA_QUANTUM_CAPACITY_EHS=

# Mining pool credentials (required for live mining runtime; keep in secret storage)
HYBA_POOL_VIABTC_URL=stratum+ssl://btc.viabtc.io:3334
HYBA_POOL_VIABTC_USERNAME=PYTHIA.001
HYBA_POOL_VIABTC_PASSWORD=replace-with-real-pool-password
HYBA_POOL_VIABTC_STRATUM_VERSION=1

# Optional fallback pools. Configure only when credentials and legal/regulatory approvals are complete.
HYBA_POOL_NICEHASH_URL=stratum+ssl://sha256.eu.nicehash.com:3334
HYBA_POOL_NICEHASH_USERNAME=
HYBA_POOL_NICEHASH_PASSWORD=
HYBA_POOL_NICEHASH_STRATUM_VERSION=1
HYBA_POOL_BRAIINS_URL=stratum2+tcp://eu.braiins-pool.com:3336
HYBA_POOL_BRAIINS_USERNAME=
HYBA_POOL_BRAIINS_PASSWORD=
HYBA_POOL_BRAIINS_STRATUM_VERSION=2
HYBA_POOL_CKPOOL_URL=stratum+tcp://solo.ckpool.org:3333
HYBA_POOL_CKPOOL_USERNAME=
HYBA_POOL_CKPOOL_PASSWORD=
HYBA_POOL_CKPOOL_STRATUM_VERSION=1
