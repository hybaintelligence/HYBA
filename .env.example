# HYBA Production Environment Template
# Copy to .env.local and populate with actual values
# NEVER commit .env.local to version control

# ── Feature Flags ──────────────────────────────────────────────────────────
# Internal operations mode (mining UI, internal telemetry)
HYBA_INTERNAL_MODE=false

# Customer-facing mode (clean product surfaces only)
HYBA_CUSTOMER_MODE=true

# ── API Configuration ──────────────────────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_BACKEND_URL=http://127.0.0.1:3001

# ── Authentication ─────────────────────────────────────────────────────────
# JWT secret for token signing (generate with: openssl rand -base64 32)
JWT_SECRET=

# API key secret for HMAC validation (generate with: openssl rand -base64 32)
HYBA_API_KEY_SECRET=

# ── Security ───────────────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated)
HYBA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Deployment ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Redis for distributed state (multi-instance deployments)
REDIS_URL=

# ── Observability ──────────────────────────────────────────────────────────
# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Telemetry polling interval (milliseconds)
VITE_TELEMETRY_POLL_INTERVAL=15000

# ── Customer Access ────────────────────────────────────────────────────────
# Customer portal base URL
VITE_CUSTOMER_PORTAL_URL=

# Support contact
VITE_SUPPORT_EMAIL=support@hyba.ai
