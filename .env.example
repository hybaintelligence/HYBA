# HYBA Fullstack Platform Configuration
# Copy to .env for local development.
# In production, inject these via a secrets manager or deployment platform.

# Runtime mode
NODE_ENV=development
HYBA_ENV=development

# Bridge server
HOST=0.0.0.0
PORT=3000
PULVINI_BACKEND_URL=http://127.0.0.1:3001
BACKEND_PROXY_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# Auth / operator credentials (required in production)
JWT_SECRET=replace-with-strong-random-secret-at-least-32-characters
# Production format: username:$argon2id$...:role[;username:$argon2id$...:role]
# IMPORTANT FOR DOCKER: In docker-compose.production.yml or .env.docker, escape $ as $$
#   Example: HYBA_OPERATOR_CREDENTIALS=operator:$$argon2id$$v=19$$m=65536...
#   Docker Compose interprets $ as variable substitution; $$ becomes literal $
# Argon2id hash generation:
# python3 - <<'PY'
# from argon2 import PasswordHasher
# print(PasswordHasher().hash("replace-with-strong-password"))
# PY
HYBA_OPERATOR_CREDENTIALS=operator:replace-with-argon2id-password-hash:mining_operator
HYBA_API_KEYS=

# Production mining safety gates
# Live Stratum is enabled automatically when NODE_ENV=production.
# In non-production, set HYBA_ENABLE_LIVE_STRATUM=true only for controlled staging smoke tests.
# Mining autoconnect is default-false; production should connect through explicit MIDAS/operator action.
# Live share submission is a separate launch gate and requires HYBA_LIVE_SHARE_APPROVAL_ID when true.
HYBA_ENABLE_LIVE_STRATUM=false
HYBA_ENABLE_MINING_AUTOCONNECT=false
HYBA_ENABLE_LIVE_SHARE_SUBMIT=false
HYBA_LIVE_SHARE_APPROVAL_ID=
HYBA_ALLOW_DEV_FIXTURES=false
HYBA_QUANTUM_CAPACITY_EHS=
HYBA_ENABLE_AUDIT_LOGGING=true
HYBA_AUDIT_LOG_DIR=logs/audit
HYBA_METRICS_DB_PATH=data/metrics.db

# Internal diagnostics
# Protects /bridge/internal/health and /bridge/metrics in production.
HYBA_INTERNAL_HEALTH_TOKEN=

# Mining pool credentials (required for live mining runtime; keep in secret storage)
# ViaBTC — Stratum V2
HYBA_POOL_VIABTC_URL=stratum2+ssl://btc.viabtc.com:443
HYBA_POOL_VIABTC_USERNAME=PYTHIA.001
HYBA_POOL_VIABTC_PASSWORD=replace-with-real-pool-password
HYBA_POOL_VIABTC_STRATUM_VERSION=2

# NiceHash SHA256 — Stratum V2
HYBA_POOL_NICEHASH_URL=stratum2+ssl://sha256.eu.nicehash.com:33334
HYBA_POOL_NICEHASH_USERNAME=PYTHIA.001
HYBA_POOL_NICEHASH_PASSWORD=replace-with-real-pool-password
HYBA_POOL_NICEHASH_STRATUM_VERSION=2

# Braiins Pool — Stratum V2
HYBA_POOL_BRAIINS_URL=stratum2+ssl://eu.braiins-pool.com:3336
HYBA_POOL_BRAIINS_USERNAME=PYTHIA.001
HYBA_POOL_BRAIINS_PASSWORD=replace-with-real-pool-password
HYBA_POOL_BRAIINS_STRATUM_VERSION=2

# Solo CKPool — Stratum V1 (no TLS)
HYBA_POOL_CKPOOL_URL=stratum+tcp://solo.ckpool.org:3333
HYBA_POOL_CKPOOL_USERNAME=PYTHIA.001
HYBA_POOL_CKPOOL_PASSWORD=replace-with-real-pool-password
HYBA_POOL_CKPOOL_STRATUM_VERSION=1

# Cloudflare Pages deployment (set in Cloudflare dashboard for /api proxying)
# The Pages Functions in functions/ proxy same-origin /api/* to this backend.
HYBA_BACKEND_URL=https://api.hyba.example.com
HYBA_EDGE_PROXY_TIMEOUT_MS=30000
# Firebase (Vite frontend env vars — set in deployment platform, never commit real values)
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DB_ID=your-firestore-db-id
