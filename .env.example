# HYBA platform local development template
# Copy to .env.local locally. Do not commit populated .env files.

NODE_ENV=development
HYBA_ENV=development
HOST=127.0.0.1
PORT=3000
PULVINI_BACKEND_URL=http://127.0.0.1:3001

# Public product surfaces
HYBA_API_KEY_SECRET=replace-with-local-random-secret
JWT_SECRET=replace-with-local-random-secret-at-least-32-characters
HYBA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HYBA_ALLOW_DEV_FIXTURES=false

# Customer access / metering
HYBA_REDIS_URL=

# Private validation substrate controls. Mining is not a product surface.
HYBA_ENABLE_LIVE_STRATUM=false
HYBA_ENABLE_LIVE_SHARE_SUBMIT=false
HYBA_ENABLE_MINING_AUTOCONNECT=false
HYBA_POOL_CONFIG_PATH=
HYBA_LIVE_SHARE_APPROVAL_ID=
HYBA_OPERATOR_APPROVAL_REQUIRED=true
HYBA_OPERATOR_APPROVAL_TIMEOUT_SECONDS=300

# Reflexive / Salamander controls
HYBA_ENABLE_REFLEXIVE_DAEMON=false
HYBA_STARTUP_SELF_HEALING_ENABLED=true
HYBA_STARTUP_SELF_HEALING_TIMEOUT_SECONDS=15.0
