{
  "name": "hyba-fullstack",
  "private": true,
  "version": "1.0.0-rc.1",
  "type": "module",
  "scripts": {
    "dev": "node dev-server.mjs",
    "build": "vite build --config vite.config.build.ts && esbuild ./src/server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.mjs",
    "start": "node -e \"process.env.NODE_ENV='production'; import('./dist/server.mjs').catch(err => { console.error(err); process.exit(1); })\"",
    "start:dev": "node dist/server.mjs",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "lint": "tsc --noEmit",
    "seed": "tsx src/db/seed.ts",
    "test:e2e:backend": "cross-env PYTHONPATH=python_backend python scripts/run_backend_e2e.py",
    "test:backend": "cross-env PYTHONPATH=python_backend python -m unittest discover -s tests -p \"test_*.py\"",
    "test:property:backend": "cross-env PYTHONPATH=python_backend python -m pytest tests/test_property_based_backend.py -v -x --tb=short",
    "test:property:frontend": "npx vitest run tests/test_property_frontend.test.ts",
    "test:property": "npm run test:property:backend && npm run test:property:frontend",
    "test:bridge": "npx vitest run tests/test_bridge_server.ts",
    "test:mining:innovation": "cross-env PYTHONPATH=python_backend python -m pytest tests/test_mining_innovation_properties.py -q",
    "test:mining:benefit": "cross-env PYTHONPATH=python_backend python -m pytest tests/test_mining_benefit_assessment.py -q",
    "test:funding:gate": "cross-env PYTHONPATH=python_backend python -m pytest tests/test_funding_engine_deployment_gate.py tests/test_mining_innovation_properties.py tests/test_mining_benefit_assessment.py -q",
    "test:all": "npm run test:property && npm run test:backend && npm run test:bridge",
    "prod:env:check": "python scripts/validate_production_env.py",
    "prod:local:gate": "python scripts/local_production_gate.py --mode rc",
    "prod:live:gate": "python scripts/local_production_gate.py --mode live",
    "prod:command-room:gate": "python scripts/local_production_gate.py --mode command-room",
    "funding:gate": "cross-env PYTHONPATH=python_backend python scripts/funding_engine_deployment_gate.py",
    "funding:accepted-share:gate": "cross-env PYTHONPATH=python_backend python scripts/funding_engine_deployment_gate.py --require-accepted-share",
    "pulvini:live-cut:check": "python scripts/pulvini_live_cut_readiness.py",
    "pulvini:live-cut:simulate": "cross-env PYTHONPATH=python_backend python scripts/pulvini_simulate_live_cut.py",
    "prod:check": "npm run live:audit && npm run cloudflare:check && npm run runtime:guard && npm run lint && npm run build && npm run test:backend && npm run test:e2e:backend",
    "docker:build": "docker build -t hyba-fullstack:local .",
    "cloudflare:check": "python scripts/check_cloudflare_deploy.py",
    "runtime:guard": "python scripts/check_no_runtime_mocks.py",
    "backend:start": "python -m uvicorn hyba_genesis_api.main:app --app-dir python_backend --host 127.0.0.1 --port 3001",
    "backend:check": "python -c \"import sys; sys.path.insert(0, 'python_backend'); import hyba_genesis_api.main; print('backend import ok')\"",
    "live:audit": "python scripts/audit_live_deployment.py",
    "test:deployment:e2e": "cross-env PYTHONPATH=python_backend python -m unittest tests.test_live_deployment_e2e -v",
    "test:deployment:property": "cross-env PYTHONPATH=python_backend python -m pytest tests/test_live_deployment_properties.py -v -x --tb=short",
    "test:deployment": "npm run test:deployment:e2e && npm run test:deployment:property",
    "test:go-live": "PYTHONPATH=python_backend python -m pytest tests/test_go_live_final_coverage.py -q",
    "test:final": "npm run test:go-live && npm run test:all && npm run test:e2e:backend && npm run test:deployment"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.14.0",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/swagger-ui-express": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "fast-check": "^4.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
