{
  "name": "hyba-fullstack",
  "private": true,
  "version": "1.0.0-rc.1",
  "type": "module",
  "scripts": {
    "dev": "node dev-server.mjs",
    "build": "vite build --config vite.config.build.ts && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.mjs",
    "start": "node dist/server.mjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "seed": "tsx src/db/seed.ts",
    "test:e2e:backend": "PYTHONPATH=python_backend python3 scripts/run_backend_e2e.py",
    "test:backend": "PYTHONPATH=python_backend python3 -m unittest discover -s tests -p \"test_*.py\"",
    "test:property:backend": "PYTHONPATH=python_backend python3 -m pytest tests/test_property_based_backend.py -v -x --tb=short",
    "test:property:frontend": "npx vitest run tests/test_property_frontend.test.ts",
    "test:property": "npm run test:property:backend && npm run test:property:frontend",
    "test:bridge": "npx vitest run tests/test_bridge_server.ts",
    "test:all": "npm run test:property && npm run test:backend && npm run test:bridge",
    "prod:env:check": "python3 scripts/validate_production_env.py",
    "prod:check": "npm run cloudflare:check && npm run runtime:guard && npm run lint && npm run build && npm run test:backend && npm run test:e2e:backend",
    "docker:build": "docker build -t hyba-fullstack:local .",
    "cloudflare:check": "python3 scripts/check_cloudflare_deploy.py",
    "runtime:guard": "python3 scripts/check_no_runtime_mocks.py"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.14.0",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "swagger-ui-express": "^5.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/swagger-ui-express": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "fast-check": "^4.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "4.19.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8"
  }
}
