[flake8]
max-line-length = 100
max-complexity = 15
exclude =
    .git,
    .venv,
    venv,
    node_modules,
    dist,
    artifacts,
    logs,
    __pycache__,
    .gitignore,
    *.pyc,
    build,
    *.egg-info
per-file-ignores =
    __init__.py:F401
    tests/*:E402
    scripts/*:E402
ignore = E203, W503, E501, E226, E704, C901, F824