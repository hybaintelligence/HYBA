# Copy this file to terraform.tfvars and fill in your actual values
# Note: Do NOT commit terraform.tfvars to version control

hyba_endpoint  = "https://api.hyba.ai"
hyba_api_key   = "your-api-key-here"
service_name   = "my-ml-service"
service_tier   = "production"
connector_type = "tensorflow"

tags = {
  environment = "production"
  team        = "ml-ops"
  cost-center = "eng-001"
}
