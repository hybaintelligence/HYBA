HYBA_POOL_CONFIG_PATH=config/mining_pools_live.json
HYBA_ENABLE_LIVE_STRATUM=true
HYBA_ENABLE_LIVE_SHARE_SUBMIT=true
HYBA_ENV=development
NODE_ENV=development
HYBA_AUTONOMY_LEVEL=autonomous
HYBA_AUTONOMOUS_MAX_HASHRATE_EHS=1.0
HYBA_PHI_COHERENCE_THRESHOLD=0.70
HYBA_REFLEXIVE_LOOP_ENABLED=true
HYBA_REFLEXIVE_LOOP_INTERVAL=60.0
HYBA_COMPRESSION_DRIVE_ENABLED=true
HYBA_OPERATOR_APPROVAL_REQUIRED=false
