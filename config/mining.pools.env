# HYBA production mining pool configuration
# Live pool connections enabled for Stratum V2 on ViaBTC
NODE_ENV=production
HYBA_ENV=production
HYBA_ALLOW_DEV_FIXTURES=false
HYBA_ENABLE_LIVE_STRATUM=true
HYBA_ENABLE_LIVE_SHARE_SUBMIT=true
HYBA_LIVE_SHARE_APPROVAL_ID=launch-approval-2026-06-11
HYBA_ENABLE_AUDIT_LOGGING=true
HYBA_ENABLE_MINING_AUTOCONNECT=true

# HYBA/PULVINI hashrate governance cap. Keep configured capacity <= 1 EH/s.
HYBA_QUANTUM_CAPACITY_EHS=1.0
HYBA_PULVINI_HASHRATE_CAP_EHS=1.0

# ViaBTC BTC pool endpoint — Stratum V2
HYBA_POOL_VIABTC_URL=stratum2+ssl://btc.viabtc.com:443
HYBA_POOL_VIABTC_USERNAME=PYTHIA.001
HYBA_POOL_VIABTC_PASSWORD=123
HYBA_POOL_VIABTC_STRATUM_VERSION=2

# NiceHash SHA256 endpoint — Stratum V2 profile
HYBA_POOL_NICEHASH_URL=stratum2+ssl://sha256.eu.nicehash.com:33334
HYBA_POOL_NICEHASH_USERNAME=PYTHIA.001
HYBA_POOL_NICEHASH_PASSWORD=123
HYBA_POOL_NICEHASH_STRATUM_VERSION=2

# Braiins Pool BTC endpoint — Stratum V2 profile
HYBA_POOL_BRAIINS_URL=stratum2+ssl://eu.braiins-pool.com:3336
HYBA_POOL_BRAIINS_USERNAME=PYTHIA.001
HYBA_POOL_BRAIINS_PASSWORD=123
HYBA_POOL_BRAIINS_STRATUM_VERSION=2

# CKPool / solo fallback — Stratum V2 proxy profile
HYBA_POOL_CKPOOL_URL=stratum2+tcp://solo.ckpool.org:3333
HYBA_POOL_CKPOOL_USERNAME=PYTHIA.001
HYBA_POOL_CKPOOL_PASSWORD=123
HYBA_POOL_CKPOOL_STRATUM_VERSION=2
