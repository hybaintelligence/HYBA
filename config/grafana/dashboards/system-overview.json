{
  "dashboard": {
    "title": "HYBA PQMC System Overview",
    "uid": "hyba-system-overview",
    "tags": ["hyba", "pqmc", "system"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "API Requests per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(hyba_api_requests_total[1m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ],
        "yaxes": [
          {
            "format": "reqps",
            "label": "Requests/sec"
          }
        ]
      },
      {
        "id": 2,
        "title": "API Latency (P95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(hyba_api_latency_seconds_bucket[1m]))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Latency (seconds)"
          }
        ]
      },
      {
        "id": 3,
        "title": "API Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(hyba_api_errors_total[1m]) / rate(hyba_api_requests_total[1m])",
            "legendFormat": "Error Rate"
          }
        ],
        "yaxes": [
          {
            "format": "percentunit",
            "label": "Error Rate"
          }
        ]
      },
      {
        "id": 4,
        "title": "API Availability",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(hyba_api_available[5m])",
            "legendFormat": "Availability"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0.99
                },
                {
                  "color": "green",
                  "value": 0.999
                }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Compute Jobs per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(hyba_compute_jobs_total[1m])",
            "legendFormat": "Jobs/sec"
          }
        ],
        "yaxes": [
          {
            "format": "jobs/sec",
            "label": "Jobs/sec"
          }
        ]
      },
      {
        "id": 6,
        "title": "Compute Job Duration (P95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(hyba_compute_job_duration_seconds_bucket[1m]))",
            "legendFormat": "Duration (seconds)"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Duration (seconds)"
          }
        ]
      },
      {
        "id": 7,
        "title": "Database Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "pg_stat_database_numbackends",
            "legendFormat": "{{datname}}"
          }
        ],
        "yaxes": [
          {
            "format": "short",
            "label": "Connections"
          }
        ]
      },
      {
        "id": 8,
        "title": "Database Query Duration (P95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(pg_stat_statements_total_exec_time_seconds_bucket[1m]))",
            "legendFormat": "{{query}}"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Duration (seconds)"
          }
        ]
      },
      {
        "id": 9,
        "title": "Redis Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
            "legendFormat": "Memory Usage"
          }
        ],
        "yaxes": [
          {
            "format": "percentunit",
            "label": "Memory Usage"
          }
        ]
      },
      {
        "id": 10,
        "title": "Redis Operations per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(redis_commands_processed_total[1m])",
            "legendFormat": "Ops/sec"
          }
        ],
        "yaxes": [
          {
            "format": "ops/sec",
            "label": "Ops/sec"
          }
        ]
      },
      {
        "id": 11,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
            "legendFormat": "{{instance}}"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "label": "CPU Usage"
          }
        ]
      },
      {
        "id": 12,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
            "legendFormat": "{{instance}}"
          }
        ],
        "yaxes": [
          {
            "format": "percentunit",
            "label": "Memory Usage"
          }
        ]
      }
    ]
  }
}
