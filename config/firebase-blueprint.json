{
  "entities": {
    "CalibrationLog": {
      "description": "Log of quantum substrate calibrations",
      "properties": {
        "expectedImprovement": {
          "type": "number"
        },
        "resonanceRadius": {
          "type": "number"
        },
        "targetIndex": {
          "type": "number"
        },
        "timestamp": {
          "format": "date-time",
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "username": {
          "type": "string"
        }
      },
      "required": [
        "userId",
        "username",
        "targetIndex",
        "resonanceRadius",
        "expectedImprovement",
        "timestamp"
      ],
      "title": "CalibrationLog",
      "type": "object"
    },
    "QuantumProduct": {
      "description": "Quantum hardware available in the catalog",
      "properties": {
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "difficultyScale": {
          "description": "Scaling factor 1-10",
          "type": "number"
        },
        "name": {
          "type": "string"
        },
        "qubitDimension": {
          "description": "Number of qubits",
          "type": "number"
        }
      },
      "required": [
        "name",
        "description",
        "category",
        "difficultyScale",
        "qubitDimension"
      ],
      "title": "QuantumProduct",
      "type": "object"
    },
    "User": {
      "description": "User profile and authentication data",
      "properties": {
        "createdAt": {
          "format": "date-time",
          "type": "string"
        },
        "passwordHash": {
          "description": "Bcrypt hashed password",
          "type": "string"
        },
        "role": {
          "enum": [
            "admin",
            "miner",
            "analyst",
            "operator"
          ],
          "type": "string"
        },
        "username": {
          "description": "Unique username",
          "type": "string"
        }
      },
      "required": [
        "username",
        "passwordHash",
        "role",
        "createdAt"
      ],
      "title": "User",
      "type": "object"
    }
  },
  "firestore": {
    "/calibrationLogs/{logId}": {
      "description": "History of system calibrations",
      "schema": "CalibrationLog"
    },
    "/products/{productId}": {
      "description": "Catalog of hardware products",
      "schema": "QuantumProduct"
    },
    "/users/{userId}": {
      "description": "Collection of user profiles",
      "schema": "User"
    }
  }
}
