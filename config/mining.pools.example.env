# HYBA production mining pool configuration template
# Copy to a secure runtime secret store or local .env file that is NOT committed.
# Replace worker/password values with the exact pool credentials approved for launch.

NODE_ENV=production
HYBA_ENV=production
HYBA_ALLOW_DEV_FIXTURES=false

# Deterministic declared capacity. This is the HYBA/PULVINI configured hashrate
# contract used for dashboards and orchestration. The production governance cap
# is 1.0 EH/s; values above this must fail validation and API submission.
HYBA_QUANTUM_CAPACITY_EHS=1.0
HYBA_PULVINI_HASHRATE_CAP_EHS=1.0

# Primary pool: ViaBTC BTC — Stratum V2 over TLS.
HYBA_POOL_VIABTC_URL=stratum2+ssl://btc.viabtc.com:443
HYBA_POOL_VIABTC_USERNAME=PYTHIA.001
HYBA_POOL_VIABTC_PASSWORD=123
HYBA_POOL_VIABTC_STRATUM_VERSION=2

# Failover pool: NiceHash SHA256 — Stratum V2 profile.
HYBA_POOL_NICEHASH_URL=stratum2+ssl://sha256.eu.nicehash.com:33334
HYBA_POOL_NICEHASH_USERNAME=PYTHIA.001
HYBA_POOL_NICEHASH_PASSWORD=123
HYBA_POOL_NICEHASH_STRATUM_VERSION=2

# Failover pool: Braiins Pool BTC — Stratum V2 profile.
HYBA_POOL_BRAIINS_URL=stratum2+ssl://eu.braiins-pool.com:3336
HYBA_POOL_BRAIINS_USERNAME=PYTHIA.001
HYBA_POOL_BRAIINS_PASSWORD=123
HYBA_POOL_BRAIINS_STRATUM_VERSION=2

# Solo fallback: CKPool. Use a Stratum V2 proxy/endpoint where available;
# otherwise set version=1 with the pool's documented stratum+tcp endpoint.
HYBA_POOL_CKPOOL_URL=stratum2+tcp://solo.ckpool.org:3333
HYBA_POOL_CKPOOL_USERNAME=PYTHIA.001
HYBA_POOL_CKPOOL_PASSWORD=123
HYBA_POOL_CKPOOL_STRATUM_VERSION=2

# Enable live Stratum connections (subscribe/authorize or SetupConnection over network).
HYBA_ENABLE_LIVE_STRATUM=true

# Enable live share submission to real pools. This requires an explicit launch
# approval identifier so production validation can prove operator intent.
HYBA_ENABLE_LIVE_SHARE_SUBMIT=true
HYBA_LIVE_SHARE_APPROVAL_ID=replace-with-approved-launch-ticket

# Enable automatic startup connection to the configured primary ViaBTC pool.
HYBA_ENABLE_MINING_AUTOCONNECT=true

# Enable structured audit logging of all mining operations for compliance and
# incident investigation.
HYBA_ENABLE_AUDIT_LOGGING=true
HYBA_AUDIT_LOG_DIR=logs/audit

# URI or identifier for your secret management service (e.g., aws://secretsmanager/... or vault://...).
# Used to fetch pool credentials and JWT secrets.
HYBA_SECRET_MANAGER_URI=

# Optional Prometheus metrics endpoint for mining telemetry.
HYBA_METRICS_ENDPOINT=
