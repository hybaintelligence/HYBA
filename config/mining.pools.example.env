# HYBA production mining pool configuration template
# Copy into the runtime environment or the deployment configuration used for launch.
# Pool profile fields below are Bitcoin/Stratum open-network routing/auth values,
# not HYBA application secrets. Private HYBA app/admin credentials remain separate.

NODE_ENV=production
HYBA_ENV=production
HYBA_ALLOW_DEV_FIXTURES=false

# Deterministic declared capacity. This is the HYBA/PULVINI configured hashrate
# contract used for dashboards and orchestration. The production governance cap
# is 1.0 EH/s; values above this must fail validation and API submission.
HYBA_QUANTUM_CAPACITY_EHS=1.0
HYBA_PULVINI_HASHRATE_CAP_EHS=1.0

# Primary pool: ViaBTC BTC. Use the exact endpoint/version approved for launch.
# Password can be the conventional Stratum value "x" unless the operator's pool
# profile requires a different value.
HYBA_POOL_VIABTC_URL=stratum+ssl://btc.viabtc.io:3334
HYBA_POOL_VIABTC_USERNAME=PYTHIA.001
HYBA_POOL_VIABTC_PASSWORD=x
HYBA_POOL_VIABTC_STRATUM_VERSION=1

# Failover pool: NiceHash SHA256. NiceHash uses worker and pool-id semantics.
HYBA_POOL_NICEHASH_URL=stratum+ssl://sha256.eu.nicehash.com:33334
HYBA_POOL_NICEHASH_WORKER=PYTHIA.001
HYBA_POOL_NICEHASH_NICEHASH_POOL_ID=replace-with-nicehash-pool-id
HYBA_POOL_NICEHASH_STRATUM_VERSION=1

# Failover pool: Braiins Pool BTC. Currently uses Stratum V1 for job-flow compatibility.
# Use "x" for pool password if the selected endpoint accepts standard Stratum auth;
# otherwise use the operator's pool value. Do not use Stratum V2 unless job-flow
# has been separately validated for V2 support.
HYBA_POOL_BRAIINS_URL=stratum+tcp://stratum.braiins.com:3333
HYBA_POOL_BRAIINS_USERNAME=PYTHIA.001
HYBA_POOL_BRAIINS_PASSWORD=x
HYBA_POOL_BRAIINS_STRATUM_VERSION=1

# Solo fallback: CKPool. Use a BTC payout address; password resolves to "x" at runtime.
HYBA_POOL_CKPOOL_URL=stratum+tcp://solo.ckpool.org:3333
HYBA_POOL_CKPOOL_BTC_ADDRESS=bc1qreplacewithyourpayoutaddress
HYBA_POOL_CKPOOL_STRATUM_VERSION=1

# Enable live Stratum connections only after the production launch checklist is
# complete. This allows network subscribe/authorize or SetupConnection traffic.
HYBA_ENABLE_LIVE_STRATUM=true

# Default-safe: live share submission must stay disabled until explicit signed
# launch approval exists. Set the approval id only for an approved live cut.
HYBA_ENABLE_LIVE_SHARE_SUBMIT=false
HYBA_LIVE_SHARE_APPROVAL_ID=

# Default-safe: autoconnect must stay disabled. Connection should be initiated by
# an authenticated operator/MIDAS action after legal, treasury, security, and ops
# approvals are complete.
HYBA_ENABLE_MINING_AUTOCONNECT=false

# Enable structured audit logging of all mining operations for compliance and
# incident investigation.
HYBA_ENABLE_AUDIT_LOGGING=true
HYBA_AUDIT_LOG_DIR=logs/audit

# Optional Prometheus metrics endpoint for mining telemetry.
HYBA_METRICS_ENDPOINT=
