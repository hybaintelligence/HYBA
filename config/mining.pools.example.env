# HYBA production mining pool configuration template
# Copy to a secure runtime secret store or local .env file that is NOT committed.
# Do not commit real usernames, wallet addresses, API keys, worker IDs, or passwords.

NODE_ENV=production
HYBA_ENV=production
HYBA_ALLOW_DEV_FIXTURES=false

# Deterministic declared capacity. This is the HYBA/PULVINI configured hashrate
# contract used for dashboards and orchestration. Use a positive numeric value.
# Example: 0.5 = 0.5 EH/s declared capacity estimate.
HYBA_QUANTUM_CAPACITY_EHS=

# NiceHash SHA256 endpoint example already used in the HYBA test contract.
HYBA_POOL_NICEHASH_URL=stratum+ssl://sha256.eu.nicehash.com:33334
HYBA_POOL_NICEHASH_USERNAME=
HYBA_POOL_NICEHASH_PASSWORD=
HYBA_POOL_NICEHASH_STRATUM_VERSION=v1

# ViaBTC BTC pool endpoint.
# Fill with the current ViaBTC BTC stratum endpoint from your ViaBTC dashboard.
HYBA_POOL_VIABTC_URL=
HYBA_POOL_VIABTC_USERNAME=
HYBA_POOL_VIABTC_PASSWORD=
HYBA_POOL_VIABTC_STRATUM_VERSION=v1

# Braiins Pool BTC endpoint.
# Fill with the current Braiins BTC stratum endpoint from your Braiins dashboard.
HYBA_POOL_BRAIINS_URL=
HYBA_POOL_BRAIINS_USERNAME=
HYBA_POOL_BRAIINS_PASSWORD=
HYBA_POOL_BRAIINS_STRATUM_VERSION=v1

# CKPool / solo CKPool endpoint.
# Fill with the current CKPool solo stratum endpoint and payout identity.
HYBA_POOL_CKPOOL_URL=
HYBA_POOL_CKPOOL_USERNAME=
HYBA_POOL_CKPOOL_PASSWORD=
HYBA_POOL_CKPOOL_STRATUM_VERSION=v1
