# HYBA_FULLSTACK production environment template
# Copy to .env.production locally, or map private HYBA values into your deployment secret store.
# Do not commit a populated .env.production file.

# Runtime mode required by scripts/validate_production_env.py
NODE_ENV=production
HYBA_ENV=production

# Bridge/API runtime
HOST=0.0.0.0
PORT=3000
PULVINI_BACKEND_URL=https://replace-with-your-fastapi-backend.example.com
BACKEND_PROXY_TIMEOUT_MS=30000
LOG_LEVEL=info

# Production HYBA authentication
# JWT_SECRET is a HYBA application secret. Generate it from a cryptographic RNG.
JWT_SECRET=replace-with-strong-random-secret-at-least-32-characters

# HYBA operator credentials are private app/admin credentials.
# Format: username:$argon2id$...:role[;username:$argon2id$...:role]
# Generate with:
#   python - <<'PY'
#   from argon2 import PasswordHasher
#   print(PasswordHasher().hash("replace-with-strong-password"))
#   PY
HYBA_OPERATOR_CREDENTIALS=operator:replace-with-argon2id-password-hash:mining_operator
HYBA_API_KEYS=
HYBA_INTERNAL_HEALTH_TOKEN=replace-with-internal-health-token

# Mining production gates
HYBA_ENABLE_LIVE_STRATUM=true
HYBA_ENABLE_AUDIT_LOGGING=true
HYBA_ALLOW_DEV_FIXTURES=false
HYBA_ENABLE_MINING_AUTOCONNECT=false
HYBA_ENABLE_LIVE_SHARE_SUBMIT=false
HYBA_LIVE_SHARE_APPROVAL_ID=
HYBA_QUANTUM_CAPACITY_EHS=1.0
HYBA_AUDIT_LOG_DIR=logs/audit
HYBA_METRICS_DB_PATH=data/metrics.db

# Database configuration
# Use DATABASE_URL to override the default SQLite database. For production, configure this to use PostgreSQL.
# Example: postgresql+psycopg2://hyba_user:replace-with-password@db-host:5432/hyba_db
DATABASE_URL=

# Metal-aware SHA-256d verifier
# Uses MLX/Metal on Apple Silicon when available; exact CPU verification remains the fallback.
HYBA_ENABLE_METAL_SHA256=true
HYBA_REQUIRE_METAL_SHA256=false
HYBA_CPU_VERIFY_WORKERS=32
HYBA_ENABLE_MLX_SHA256_ANY_PLATFORM=false

# Configure at least one real Bitcoin/Stratum pool profile.
# These are open-network routing/auth parameters, not HYBA application secrets:
# worker name, payout address, pool id, and the standard Stratum password value "x".

# ViaBTC — Stratum V2/V1 according to the selected endpoint.
HYBA_POOL_VIABTC_URL=stratum2+ssl://btc.viabtc.com:443
HYBA_POOL_VIABTC_USERNAME=PYTHIA.001
HYBA_POOL_VIABTC_PASSWORD=x
HYBA_POOL_VIABTC_STRATUM_VERSION=2

# CKPool solo fallback — BTC payout address only; password resolves to "x" at runtime.
# HYBA_POOL_CKPOOL_URL=stratum+tcp://solo.ckpool.org:3333
# HYBA_POOL_CKPOOL_BTC_ADDRESS=bc1qreplacewithyourpayoutaddress
# HYBA_POOL_CKPOOL_STRATUM_VERSION=1

# NiceHash SHA256 — worker plus NiceHash pool id semantics.
# HYBA_POOL_NICEHASH_URL=stratum+ssl://sha256.eu.nicehash.com:3334
# HYBA_POOL_NICEHASH_WORKER=PYTHIA.001
# HYBA_POOL_NICEHASH_NICEHASH_POOL_ID=replace-with-nicehash-pool-id
# HYBA_POOL_NICEHASH_STRATUM_VERSION=1

# PYTHIA Autonomous Mining Controller (production)
# Controls the autonomous decision-making and Reflexive Knowledge Loop.
# See python_backend/pythia_mining/autonomous_mining_controller.py for full details.
HYBA_AUTONOMY_LEVEL=advisory
# Valid levels: manual, advisory, supervised, autonomous, emergency
HYBA_AUTONOMOUS_MAX_HASHRATE_EHS=0.5
# Hard mission-memory limit is 1.0 EH/s; this value is clamped to that.
HYBA_AUTONOMOUS_MAX_POWER_WATTS=500.0
HYBA_PHI_COHERENCE_THRESHOLD=0.70
HYBA_REFLEXIVE_LOOP_ENABLED=true
HYBA_REFLEXIVE_LOOP_INTERVAL=60.0
HYBA_COMPRESSION_DRIVE_ENABLED=true
HYBA_OPERATOR_APPROVAL_REQUIRED=true
# Approval service should reject on timeout and audit operator identity.
HYBA_OPERATOR_APPROVAL_TIMEOUT_SECONDS=300
HYBA_AUTONOMY_STATE_DIR=artifacts/autonomous_mining
# Store these values in a managed secret/config service in production, not shell history.
HYBA_AUTONOMY_AUDIT_RETENTION=7d-hot-90d-warm-365d-cold

# Frontend deployment values
HYBA_BACKEND_URL=https://replace-with-your-api.example.com
HYBA_EDGE_PROXY_TIMEOUT_MS=30000
VITE_FIREBASE_PROJECT_ID=replace-with-project-id
VITE_FIREBASE_APP_ID=replace-with-app-id
VITE_FIREBASE_API_KEY=replace-with-api-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-project.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=replace-with-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DB_ID=replace-with-firestore-db-id
